# --- Builder bases per architecture ---
# x86_64/arm64: UBI 9 Python 3.12
# ppc64le/s390x: vllm-spyre (ships vllm + torch + deps pre-installed)
#
# SPYRE_IMAGE has NO default so the Konflux pre-pull step cannot resolve
# FROM ${SPYRE_IMAGE} and skips it.  The actual value is passed via
# --build-arg in the PipelineRun.  On arm64 the builder-ppc64le/s390x
# stages are unreachable so buildah (--skip-unused-stages, default true)
# never pulls the image.
ARG TARGETARCH
ARG UBI9_IMAGE=registry.access.redhat.com/ubi9/python-312:9.7
ARG SPYRE_IMAGE
FROM ${UBI9_IMAGE} AS builder-amd64
FROM ${UBI9_IMAGE} AS builder-arm64
FROM ${SPYRE_IMAGE} AS builder-ppc64le
FROM ${SPYRE_IMAGE} AS builder-s390x

# Build stage
FROM builder-${TARGETARCH} AS builder

# Set working directory
WORKDIR /app

# Run as root for build stage
USER root

# numpy links against system openblas on UBI9 (rhoai wheels don't bundle it).
# Only needed on x86_64/aarch64 (UBI9 base); vllm-spyre (ppc64le/s390x)
# already ships openblas.
ARG TARGETARCH
RUN if [ "$TARGETARCH" = "amd64" ] || [ "$TARGETARCH" = "arm64" ]; then \
        dnf install -y openblas-threads && \
        dnf clean all && rm -rf /var/cache/dnf; \
    fi

# use requirements.txt for konflux
COPY requirements.txt /app/requirements.txt
# --no-deps: all transitive deps are already pinned in requirements.txt.
# This also prevents pip from pulling intel-cmplr-lib-ur (a transitive dep
# of intel-openmp that's excluded because it fails hermetic prefetch and
# is not needed for CPU-only torch).
RUN pip install --no-cache-dir --no-deps -r requirements.txt

# --- Runtime bases per architecture ---
FROM ${UBI9_IMAGE} AS runtime-amd64
FROM ${UBI9_IMAGE} AS runtime-arm64
FROM ${SPYRE_IMAGE} AS runtime-ppc64le
FROM ${SPYRE_IMAGE} AS runtime-s390x

# Runtime stage
FROM runtime-${TARGETARCH} AS runtime

# Set build arguments
ARG HEALTH_PORT=8082

# Set working directory
WORKDIR /app

# Copy installed dependencies from build stage (UBI uses /opt/app-root/)
COPY --from=builder /opt/app-root/lib/python3.12/site-packages /opt/app-root/lib/python3.12/site-packages
# Copy executables from build stage
COPY --from=builder /opt/app-root/bin/ /opt/app-root/bin/

# Need root for chown operations
USER root

# Install openblas-threads in runtime (numpy needs libopenblasp.so.0).
# Only on x86_64/aarch64; vllm-spyre (ppc64le/s390x) already ships openblas.
ARG TARGETARCH
RUN if [ "$TARGETARCH" = "amd64" ] || [ "$TARGETARCH" = "arm64" ]; then \
        dnf install -y openblas-threads && \
        dnf clean all && rm -rf /var/cache/dnf; \
    fi

# Copy project files into the image

COPY run_grpc_server.py /app/
COPY tokenizer_grpc_service.py /app/tokenizer_grpc_service.py
COPY tokenizers/ /app/tokenizers/
COPY utils/ /app/utils/
COPY tokenizer_service/ /app/tokenizer_service/
COPY tokenizerpb/ /app/tokenizerpb/

# Create directory for UDS socket
RUN mkdir -p /tmp/tokenizer && chown 65532:65532 /tmp/tokenizer

# Create tokenizer cache directories and set permissions
ENV TOKENIZERS_DIR=/app/tokenizers
RUN mkdir -p /app/tokenizers && chown -R 65532:65532 /app/tokenizers
# Create and set permissions for Hugging Face cache directory
RUN mkdir -p /.cache && chown -R 65532:65532 /.cache
# Add non-root user entry so getpwuid(65532) works (required by torch/getpass)
RUN echo "nonroot:x:65532:65532:nonroot:/home/nonroot:/usr/sbin/nologin" >> /etc/passwd && \
    mkdir -p /home/nonroot && chown 65532:65532 /home/nonroot

# Set TMPDIR to the UDS socket directory, which is always mounted as a
# writable emptyDir by KServe — even when readOnlyRootFilesystem is enforced
ENV TMPDIR=/tmp/tokenizer

# Switch to non-root user
USER 65532:65532

# Expose health check port (configurable via build arg)
EXPOSE ${HEALTH_PORT}

# Startup command: run direct gRPC server
ENTRYPOINT ["python", "/app/run_grpc_server.py"]

# Test stage - validates critical imports without affecting final image size
FROM runtime as test
RUN python -c "\
from tokenizer_service.renderer import RendererService; \
from tokenizer_service.tokenizer import TokenizerService; \
from tokenizer_grpc_service import create_grpc_server; \
print('smoke test passed')"

# Final stage
FROM runtime

LABEL com.redhat.component="odh-llm-d-kv-cache-rhel9" \
      name="odh-llm-d-kv-cache-rhel9" \
      description="odh-llm-d-kv-cache" \
      summary="odh-llm-d-kv-cache" \
      maintainer="['managed-open-data-hub@redhat.com']" \
      io.k8s.display-name="odh-llm-d-kv-cache" \
      io.k8s.description="odh-llm-d-kv-cache" \
      com.redhat.license_terms="https://www.redhat.com/licenses/Red_Hat_Standard_EULA_20191108.pdf"